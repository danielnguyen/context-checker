{
  "manifest_version": 3,
  "name": "ContextChecker",
  "version": "0.1.0",
  "description": "Highlights context, sourcing, sponsorship, and transparency signals on YouTube.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
